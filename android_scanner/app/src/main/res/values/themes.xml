<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.HWLedger" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/apple_blue</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="Theme.HWLedger" parent="Base.Theme.HWLedger" />

    <!-- Apple Style Card -->
    <style name="AppleCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <!-- Apple Style Button -->
    <style name="AppleButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">14dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>
</resources>